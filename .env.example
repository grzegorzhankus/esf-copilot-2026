# LLM Configuration for DGX Spark

# NVIDIA NIM API (Recommended for DGX Spark)
# Get your API key from: https://build.nvidia.com/
NVIDIA_API_KEY=nvapi-your-api-key-here
NVIDIA_NIM_URL=https://integrate.api.nvidia.com/v1

# Ollama Configuration (Local Fallback)
OLLAMA_BASE_URL=http://localhost:11434

# Preferred Model (optional)
# Options: llama-4-maverick, deepseek-v3, mistral-large, qwen3
LLM_MODEL=llama-4-maverick

# LLM Parameters
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096
LLM_TIMEOUT=60

# Application Settings
APP_ENV=production
DEBUG=false
LOG_LEVEL=INFO
