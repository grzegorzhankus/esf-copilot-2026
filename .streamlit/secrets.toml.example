# Streamlit Cloud Secrets Configuration
# Copy these values to Streamlit Cloud Settings > Secrets
# https://share.streamlit.io > Your App > Settings > Secrets

NVIDIA_API_KEY = "nvapi-your-api-key-here"
NVIDIA_NIM_URL = "https://integrate.api.nvidia.com/v1"
LLM_MODEL = "llama-4-maverick"
LLM_TEMPERATURE = "0.1"
LLM_MAX_TOKENS = "4096"
